            "output_sha512": "08c52194c4a6cbae27bfbcbba8b8dca55794953c968512b513dc431bf22c3d4e13e57eade9f3b46d2b7df4d17e53508285d51926f885d4b9c0f5458e723e50d9",
            "output_size": 481,
            "source": [
              {
                "content": "import json\ndef lambda_handler(event, context):\n    for record in event['Records']:\n        body = json.loads(record['body'])\n        if 'Message' in body:\n            sns_message = json.loads(body['Message'])\n            if 'Records' in sns_message:\n                s3_info = sns_message['Records'][0]['s3']\n                print(f\"🚀 [TF-PROCESADOR] ¡Nuevo archivo detectado!\")\n                print(f\"📁 Bucket: {s3_info['bucket']['name']}\")\n                print(f\"📄 Archivo: {s3_info['object']['key']}\")\n                print(f\"⚖️ Tamaño: {s3_info['object']['size']} bytes\")\n    return {'statusCode': 200, 'body': json.dumps('Procesado')}\n",
                "filename": "index.py"
              }
            ],
            "source_content": null,
            "source_content_filename": null,
            "source_dir": null,
            "source_file": null,
            "type": "zip"
          },
          "sensitive_attributes": []
        }
      ]
    },
